{
  "name": "crm-collab",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "description": "Collaboration and project-management service for the CIMA CRM multi-repo platform.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:ensure-audit-partitions": "tsx src/db/scripts/run-ensure-audit-partitions.ts",
    "test:smoke:gateway": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-gateway-smoke.ps1",
    "hydrate:identity-snapshots": "tsx src/scripts/hydrate-identity-snapshots.ts",
    "dlq:auth:list": "tsx src/scripts/auth-events-dlq.ts list",
    "dlq:auth:replay": "tsx src/scripts/auth-events-dlq.ts replay",
    "test:unit": "vitest run",
    "preinstall": "pnpm dlx only-allow pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebasCarvajal11/crm-collab.git"
  },
  "bugs": {
    "url": "https://github.com/SebasCarvajal11/crm-collab/issues"
  },
  "homepage": "https://github.com/SebasCarvajal11/crm-collab#readme",
  "dependencies": {
    "@sebascarvajal11/cima-contracts": "github:SebasCarvajal11/cima-contracts#v0.1.1",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}

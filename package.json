{
  "name": "crm-collab",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:ensure-audit-partitions": "tsx src/db/scripts/run-ensure-audit-partitions.ts",
    "test:smoke:gateway": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-gateway-smoke.ps1",
    "cleanup:orphan-oci": "tsx src/scripts/run-orphan-oci-cleanup.ts",
    "worker:orphan-oci": "tsx src/workers/orphan-oci-cleanup.worker.ts",
    "preinstall": "pnpm dlx only-allow pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebasCarvajal11/crm-collab.git"
  },
  "bugs": {
    "url": "https://github.com/SebasCarvajal11/crm-collab/issues"
  },
  "homepage": "https://github.com/SebasCarvajal11/crm-collab#readme",
  "dependencies": {
    "oci-common": "^2.118.1",
    "oci-objectstorage": "^2.118.1",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3"
  }
}

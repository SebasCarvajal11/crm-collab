DATABASE_URL=postgresql://root:<password>@postgres_db:5432/crm_database
PORT=3001
NODE_ENV=production
MOD_COLLAB_CORS=false
CORS_ORIGIN=https://crm.example.com
MOD_MEDIA_URL=http://media:3002
MOD_AUTH_URL=http://auth:3000
TRUST_GATEWAY_JWT_HEADERS=true
GATEWAY_TRUST_SECRET=
OCI_CONFIG_FILE_PATH=/opt/cima/secrets/oci.config
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=
OCI_BUCKET=crm-docs-private
DOC_PAR_TTL_SECONDS=300
OCI_PAR_PRUNE_MAX=80
OCI_ORPHAN_GRACE_MS=3600000
OCI_ORPHAN_CLEANUP_INTERVAL_MS=3600000

DATABASE_URL=postgresql://collab_user:collabpassword@localhost:25432/crm_database
DB_SCHEMA=schema_collab
PORT=3001
NODE_ENV=development
MOD_COLLAB_CORS=false
CORS_ORIGIN=http://localhost:5173

# JWT de servicio (crm-collab) para firmar comandos enviados a crm-media
SERVICE_JWT_PRIVATE_KEY=
SERVICE_JWT_PUBLIC_KEY=
SERVICE_JWT_KID=collab-service-rsa-1

REDIS_URL=redis://127.0.0.1:16379
AUTH_EVENTS_STREAM_KEY=stream:auth.identity
AUTH_EVENTS_CONSUMER_GROUP=group:collab.auth-identity
AUTH_EVENTS_MAX_RETRIES=3
AUTH_EVENTS_PENDING_IDLE_MS=30000
COLLAB_EVENTS_DLQ_STREAM_KEY=stream:collab.identity-dlq
MEDIA_COMMANDS_STREAM_KEY=stream:collab.media-commands
MEDIA_RESPONSES_STREAM_KEY=stream:media.asset-responses
MEDIA_RESPONSES_CONSUMER_GROUP=group:collab.media-responses
MEDIA_COMMAND_TIMEOUT_MS=8000
# JWKS dinámico (URL del endpoint de crm-auth):
JWKS_URI=http://localhost:3000/.well-known/jwks.json
JWKS_CACHE_TTL_MS=300000

# Tiempo base de expiracion que collab solicita a crm-media para URLs de carga.
DOC_PAR_TTL_SECONDS=300

# Rate limiting
RATE_LIMIT_COLLAB_CHAT_MAX=40
RATE_LIMIT_COLLAB_CHAT_WINDOW_MS=60000
RATE_LIMIT_COLLAB_FILE_UPLOAD_MAX=40
RATE_LIMIT_COLLAB_FILE_UPLOAD_WINDOW_MS=900000
RATE_LIMIT_COLLAB_PROJECT_MAX=15
RATE_LIMIT_COLLAB_PROJECT_WINDOW_MS=3600000
RATE_LIMIT_COLLAB_DEFAULT_MAX=100
RATE_LIMIT_COLLAB_DEFAULT_WINDOW_MS=900000


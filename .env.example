DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_cima
PORT=3001
NODE_ENV=development
MOD_COLLAB_CORS=false
CORS_ORIGIN=http://localhost:5173
MOD_MEDIA_URL=http://localhost:3002
TRUST_GATEWAY_JWT_HEADERS=true
GATEWAY_TRUST_SECRET=cima-local-gateway-trust-secret-do-not-use-production-2026
# Solo requerido cuando TRUST_GATEWAY_JWT_HEADERS=false:
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_ISS=

# Oracle Cloud Object Storage (S3-compatible)
OCI_NAMESPACE=your-tenancy-namespace
OCI_REGION=sa-saopaulo-1
OCI_ACCESS_KEY=your-access-key
OCI_SECRET_KEY=your-secret-key
OCI_BUCKET=cima-crm-files

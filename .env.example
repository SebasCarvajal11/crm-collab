DATABASE_URL=postgresql://collab_user:collabpassword@localhost:15432/crm_database
DB_SCHEMA=schema_collab
PORT=3001
NODE_ENV=development
MOD_COLLAB_CORS=false
CORS_ORIGIN=http://localhost:5173
TRUST_GATEWAY_JWT_HEADERS=true
GATEWAY_TRUST_SECRET=cima-local-gateway-trust-secret-do-not-use-production-2026
REDIS_URL=redis://127.0.0.1:16379
AUTH_EVENTS_STREAM_KEY=auth:events
AUTH_EVENTS_CONSUMER_GROUP=collab-auth-consumers
AUTH_EVENTS_MAX_RETRIES=3
AUTH_EVENTS_PENDING_IDLE_MS=30000
COLLAB_EVENTS_DLQ_STREAM_KEY=collab:events:dlq
MEDIA_COMMANDS_STREAM_KEY=media:commands
MEDIA_RESPONSES_STREAM_KEY=media:responses
MEDIA_RESPONSES_CONSUMER_GROUP=collab-media-response-consumers
MEDIA_COMMAND_TIMEOUT_MS=8000
# Solo requerido cuando TRUST_GATEWAY_JWT_HEADERS=false:
# Opción A — clave pública estática (PEM SPKI):
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_ISS=
# Opción B — JWKS dinámico (URL del endpoint de crm-auth):
# JWKS_URI=http://auth:3000/.well-known/jwks.json
# JWKS_CACHE_TTL_MS=300000

# Tiempo base de expiracion que collab solicita a crm-media para URLs de carga.
DOC_PAR_TTL_SECONDS=300

DATABASE_URL=postgresql://root:rootpassword@localhost:5432/crm_database
PORT=3001
NODE_ENV=development
MOD_COLLAB_CORS=false
CORS_ORIGIN=http://localhost:5173
MOD_MEDIA_URL=http://localhost:3002
MOD_AUTH_URL=http://localhost:3000
TRUST_GATEWAY_JWT_HEADERS=true
GATEWAY_TRUST_SECRET=cima-local-gateway-trust-secret-do-not-use-production-2026
# Solo requerido cuando TRUST_GATEWAY_JWT_HEADERS=false:
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_ISS=

# Oracle Object Storage. Usa un archivo local fuera del repo o una ruta portable
# propia del entorno. No commitear credenciales ni llaves privadas.
OCI_CONFIG_FILE_PATH=
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=
OCI_BUCKET=crm-docs-private
DOC_PAR_TTL_SECONDS=300
OCI_PAR_PRUNE_MAX=80
OCI_ORPHAN_GRACE_MS=3600000
OCI_ORPHAN_CLEANUP_INTERVAL_MS=3600000
